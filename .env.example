# Census Configuration
# Copy this file to .env and fill in your actual values

# Optional but recommended: Census API key (free at https://api.census.gov/data/key_signup.html)
# Without a key, requests are limited to 500/day
CENSUS_API_KEY=your_census_api_key_here

# Optional: Base URL (defaults to https://api.census.gov/data)
# TAP_CENSUS_API_URL=https://api.census.gov/data

# Optional: Years to extract (defaults to [2020, 2021, 2022, 2023])
# TAP_CENSUS_YEARS=[2015, 2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023]

# Optional: Max requests per minute (defaults to 60)
# TAP_CENSUS_MAX_REQUESTS_PER_MINUTE=60
